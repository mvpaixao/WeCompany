# Copie para .env e preencha os valores

SECRET_KEY=troque-isso-por-uma-chave-secreta-forte

# MySQL — PythonAnywhere
# DB_NAME:  mpaixao$nomedoBanco  (crie em pythonanywhere.com > Databases)
DB_NAME=mpaixao$ai_company
DB_USER=mpaixao
DB_PASSWORD=
DB_HOST=mpaixao.mysql.pythonanywhere-services.com
DB_PORT=3306

# AI & GitHub (também configurável por usuário no Controller da UI)
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Domínio PythonAnywhere
PYTHONANYWHERE_DOMAIN=mpaixao.pythonanywhere.com
